    <Compile Include="InputGetKeyUpPatch.cs" />
    <Compile Include="InputGetKeyUpStringPatch.cs" />
    <Compile Include="InsectNetFarm.cs" />
    <Compile Include="LocalizationManager.cs" />
    <Compile Include="LodSettingsFeature.cs" />
    <Compile Include="HideJumpButtonFeature.cs" />
    <Compile Include="MelonLoaderPlugin.cs" />
    <Compile Include="ModCoroutines.cs" />
    <Compile Include="ModLogger.cs" />
    <Compile Include="PetFeedFeature.cs" />
    <Compile Include="PetPlayFeature.cs" />
    <Compile Include="Properties\AssemblyInfo.cs" />
    <Compile Include="PuzzleNetFeature.cs" />
    <Compile Include="TransformPositionPatch.cs" />
    <Compile Include="TransformRotationPatch.cs" />
    <Compile Include="WarehouseBypassFeature.cs" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Assets\tree.png" />
    <EmbeddedResource Include="Assets\rare_tree.png" />
  </ItemGroup>

  <ItemGroup>
    <None Include="Localization\*.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>
</Project>
