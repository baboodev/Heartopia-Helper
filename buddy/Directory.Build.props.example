<Project>
  <!--
    SETUP INSTRUCTIONS:

    1. Copy this file to "Directory.Build.props" in this folder (buddy/).

    2. Set HeartopiaDir to your game install root (folder containing MelonLoader/ and/or BepInEx/).

    3. Do not commit Directory.Build.props — it is git-ignored.
  -->

  <PropertyGroup>
    <HeartopiaDir>C:\Path\To\Heartopia</HeartopiaDir>
  </PropertyGroup>
</Project>
